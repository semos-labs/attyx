{
  "title": "Attyx numpad test",
  "rules": [{
    "description": "Right-Option held = numpad layer (no modifier leak)",
    "manipulators": [
      {
        "type": "basic",
        "from": { "key_code": "right_option" },
        "to": [{ "set_variable": { "name": "numpad_layer", "value": 1 } }],
        "to_after_key_up": [{ "set_variable": { "name": "numpad_layer", "value": 0 } }]
      },
      {
        "type": "basic",
        "conditions": [{ "type": "variable_if", "name": "numpad_layer", "value": 1 }],
        "from": { "key_code": "0", "modifiers": { "optional": ["any"] } },
        "to": [{ "key_code": "keypad_0" }]
      },
      {
        "type": "basic",
        "conditions": [{ "type": "variable_if", "name": "numpad_layer", "value": 1 }],
        "from": { "key_code": "1", "modifiers": { "optional": ["any"] } },
        "to": [{ "key_code": "keypad_1" }]
      },
      {
        "type": "basic",
        "conditions": [{ "type": "variable_if", "name": "numpad_layer", "value": 1 }],
        "from": { "key_code": "2", "modifiers": { "optional": ["any"] } },
        "to": [{ "key_code": "keypad_2" }]
      },
      {
        "type": "basic",
        "conditions": [{ "type": "variable_if", "name": "numpad_layer", "value": 1 }],
        "from": { "key_code": "3", "modifiers": { "optional": ["any"] } },
        "to": [{ "key_code": "keypad_3" }]
      },
      {
        "type": "basic",
        "conditions": [{ "type": "variable_if", "name": "numpad_layer", "value": 1 }],
        "from": { "key_code": "4", "modifiers": { "optional": ["any"] } },
        "to": [{ "key_code": "keypad_4" }]
      },
      {
        "type": "basic",
        "conditions": [{ "type": "variable_if", "name": "numpad_layer", "value": 1 }],
        "from": { "key_code": "5", "modifiers": { "optional": ["any"] } },
        "to": [{ "key_code": "keypad_5" }]
      },
      {
        "type": "basic",
        "conditions": [{ "type": "variable_if", "name": "numpad_layer", "value": 1 }],
        "from": { "key_code": "6", "modifiers": { "optional": ["any"] } },
        "to": [{ "key_code": "keypad_6" }]
      },
      {
        "type": "basic",
        "conditions": [{ "type": "variable_if", "name": "numpad_layer", "value": 1 }],
        "from": { "key_code": "7", "modifiers": { "optional": ["any"] } },
        "to": [{ "key_code": "keypad_7" }]
      },
      {
        "type": "basic",
        "conditions": [{ "type": "variable_if", "name": "numpad_layer", "value": 1 }],
        "from": { "key_code": "8", "modifiers": { "optional": ["any"] } },
        "to": [{ "key_code": "keypad_8" }]
      },
      {
        "type": "basic",
        "conditions": [{ "type": "variable_if", "name": "numpad_layer", "value": 1 }],
        "from": { "key_code": "9", "modifiers": { "optional": ["any"] } },
        "to": [{ "key_code": "keypad_9" }]
      },
      {
        "type": "basic",
        "conditions": [{ "type": "variable_if", "name": "numpad_layer", "value": 1 }],
        "from": { "key_code": "return_or_enter", "modifiers": { "optional": ["any"] } },
        "to": [{ "key_code": "keypad_enter" }]
      },
      {
        "type": "basic",
        "conditions": [{ "type": "variable_if", "name": "numpad_layer", "value": 1 }],
        "from": { "key_code": "equal_sign", "modifiers": { "optional": ["any"] } },
        "to": [{ "key_code": "keypad_plus" }]
      },
      {
        "type": "basic",
        "conditions": [{ "type": "variable_if", "name": "numpad_layer", "value": 1 }],
        "from": { "key_code": "hyphen", "modifiers": { "optional": ["any"] } },
        "to": [{ "key_code": "keypad_hyphen" }]
      },
      {
        "type": "basic",
        "conditions": [{ "type": "variable_if", "name": "numpad_layer", "value": 1 }],
        "from": { "key_code": "period", "modifiers": { "optional": ["any"] } },
        "to": [{ "key_code": "keypad_period" }]
      },
      {
        "type": "basic",
        "conditions": [{ "type": "variable_if", "name": "numpad_layer", "value": 1 }],
        "from": { "key_code": "slash", "modifiers": { "optional": ["any"] } },
        "to": [{ "key_code": "keypad_slash" }]
      },
      {
        "type": "basic",
        "conditions": [{ "type": "variable_if", "name": "numpad_layer", "value": 1 }],
        "from": { "key_code": "8", "modifiers": { "mandatory": ["shift"], "optional": ["any"] } },
        "to": [{ "key_code": "keypad_asterisk" }]
      }
    ]
  }]
}
