# Attyx configuration
#
# Place this file at:
#   Linux:  $XDG_CONFIG_HOME/attyx/attyx.toml  (default: ~/.config/attyx/attyx.toml)
#   macOS:  $XDG_CONFIG_HOME/attyx/attyx.toml  (default: ~/.config/attyx/attyx.toml)
#
# All values shown below are the defaults. Uncomment and change as needed.

[font]
# family = "JetBrains Mono"
# size = 14
# cell_width = 0              # 0 = auto from font; or fixed points (e.g. 10); or "110%" of font-derived
# cell_height = 0             # 0 = auto from font; or fixed points (e.g. 20); or "115%" of font-derived
# fallback = ["Symbols Nerd Font Mono", "Noto Color Emoji"]

[theme]
# name = "default"

[scrollback]
# lines = 20000        # 0 = disable scrollback

[reflow]
# enabled = true

[cursor]
# shape = "block"      # "block" | "beam" | "underline"
# blink = true

[program]
# shell = "/bin/zsh"   # default: $SHELL or /bin/sh
# args = ["-l"]        # extra arguments passed to the shell

[logging]
# level = "info"       # "err" | "warn" | "info" | "debug" | "trace"
# file = "/tmp/attyx.log"   # append logs to file in addition to stderr

[background]
# Window background opacity: 0.0 (fully transparent) to 1.0 (fully opaque).
# Values < 1.0 enable composited transparency.
# opacity = 1.0

# Background blur radius. Only applies when opacity < 1.0.
# On macOS: activates NSVisualEffectView (system compositor blur).
# On Linux: accepted but blur is compositor-dependent (KDE Plasma, etc.).
# blur = 30

[window]
# Show or hide the window title bar. Resize handles are preserved on macOS.
# On Linux: removes all window decorations (title bar + borders);
# resizing from edges depends on the compositor/window manager.
# decorations = true

# Padding between the window edge and the terminal grid (logical pixels).
# Shorthands: padding sets all sides; padding_x = left+right; padding_y = top+bottom.
# More-specific keys override less-specific ones.
# padding = 0
# padding_x = 0
# padding_y = 0
# padding_left = 0
# padding_right = 0
# padding_top = 0
# padding_bottom = 0
